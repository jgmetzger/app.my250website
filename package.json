{
  "name": "app-my250website",
  "version": "0.1.0",
  "private": true,
  "description": "Single-user UK hospitality lead-gen + outreach CRM for James Metzger / Websites for Bars & Restaurants",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --filter @app/web dev",
    "dev:api": "pnpm --filter @app/api dev",
    "build:web": "pnpm --filter @app/web build",
    "build:api": "pnpm --filter @app/api build",
    "build": "pnpm -r build",
    "deploy:api": "pnpm --filter @app/api deploy",
    "deploy:web": "wrangler pages deploy apps/web/dist --project-name=app-my250website",
    "db:create": "wrangler d1 create wfbr-crm",
    "db:migrate": "wrangler d1 execute wfbr-crm --file=migrations/0001_init.sql --remote",
    "db:migrate:local": "wrangler d1 execute wfbr-crm --file=migrations/0001_init.sql --local",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0"
  }
}
